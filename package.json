{
  "name": "protein-log",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "batch:import": "tsx src/batch/import-source-texts.ts",
    "batch:classify": "tsx src/batch/protein-classify.ts",
    "batch:import-and-classify": "npm run batch:import && npm run batch:classify",
    "batch:backfill-amazon-prices": "tsx src/batch/backfill-amazon-weight.ts",
    "batch:backfill-embeddings": "tsx src/batch/backfill-embeddings.ts",
    "batch:fetch-amazon-details": "tsx src/batch/fetch-amazon-product-details.ts",
    "batch:scrape-iherb": "tsx src/batch/scrape-iherb.ts",
    "batch:enrich-myprotein-nutrition": "tsx src/batch/enrich-myprotein-nutrition.ts",
    "daily:scrape": "curl -X POST http://localhost:3000/api/scrape-protein && curl -X POST http://localhost:3000/api/manufacturers/scrape",
    "daily:full": "npm run daily:scrape && npm run batch:scrape-iherb && npm run batch:fetch-amazon-details && npm run batch:backfill-amazon-prices && npm run batch:import-and-classify"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@supabase/supabase-js": "^2.99.0",
    "cheerio": "^1.0.0",
    "openai": "^4.83.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
